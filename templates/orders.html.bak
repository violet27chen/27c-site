{% extends "base.html" %}

{% block title %}我的订单 - 27c.site{% endblock %}

{% block content %}
<div class="orders-page">
    <div class="page-header">
        <h1>我的订单</h1>
        <p>查看购买记录和下载链接</p>
    </div>

    {% if orders %}
        <div class="orders-list">
            {% for order in orders %}
                <div class="order-card">
                    <div class="order-header">
                        <div>
                            <span class="order-no">订单号: {{ order.order_no }}</span>
                            <span class="order-date">{{ order.created_at.strftime('%Y-%m-%d %H:%M') }}</span>
                        </div>
                        <span class="order-status status-{{ order.status }}">
                            {% if order.status == 'paid' %}已付款
                            {% elif order.status == 'failed' %}已过期
                            {% else %}待付款{% endif %}
                        </span>
                    </div>

                    <div class="order-body">
                        <div class="order-product">
                            {% if order.image_url %}
                                <img src="{{ order.image_url }}" alt="{{ order.product_name }}" class="order-thumb">
                            {% else %}
                                <div class="order-thumb-placeholder">{{ order.product_name[:1] }}</div>
                            {% endif %}
                            <div>
                                <h3 class="order-product-name">{{ order.product_name }}</h3>
                                <p class="order-amount">¥{{ "%.2f"|format(order.amount) }}</p>
                            </div>
                        </div>

                        {% if order.status == 'paid' and order.quark_link %}
                            <div class="order-download">
                                <h4>下载链接</h4>
                                <a href="{{ order.quark_link }}" target="_blank" rel="noopener" class="download-link">
                                    {{ order.quark_link }}
                                    <span class="link-arrow">↗</span>
                                </a>
                                <p class="download-hint">点击链接跳转到网盘下载</p>
                            </div>
                        {% elif order.status == 'pending' %}
                            <div class="order-pending">
                                <p>订单待支付，请在3分钟内完成支付</p>
                                <a href="{{ url_for('product_detail', product_id=order.product_id) }}" class="btn btn-primary btn-sm">重新购买</a>
                            </div>
                        {% elif order.status == 'failed' %}
                            <div class="order-failed">
                                <p>订单已过期，支付超时未完成</p>
                                <a href="{{ url_for('product_detail', product_id=order.product_id) }}" class="btn btn-primary btn-sm">重新购买</a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <p>还没有订单</p>
            <a href="{{ url_for('index') }}" class="btn btn-primary">去逛逛</a>
        </div>
    {% endif %}
</div>
{% endblock %}
