<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>我的资源 - 27c.site</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { overflow-x: hidden !important; }
        body { overflow-x: hidden !important; width: 100%; max-width: 100vw; }
        body { font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif; background: #f5f5f5; color: #333; }
        .header { background: #171717; color: #fff; padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { font-size: 18px; font-weight: 600; }
        .header a { color: #aaa; text-decoration: none; font-size: 14px; }
        .header a:hover { color: #fff; }
        .container { max-width: 1100px; margin: 24px auto; padding: 0 16px; overflow: hidden; }
        .stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 24px; }
        .stat-card { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
        .stat-card h3 { font-size: 13px; color: #888; margin-bottom: 8px; }
        .stat-card .num { font-size: 28px; font-weight: 700; color: #171717; }
        .toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .toolbar h2 { font-size: 16px; }
        .btn { display: inline-block; padding: 8px 16px; border: none; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; text-decoration: none; transition: opacity .2s; }
        .btn:hover { opacity: .85; }
        .btn-primary { background: #171717; color: #fff; }
        .btn-danger { background: #e53e3e; color: #fff; }
        .btn-sm { padding: 4px 10px; font-size: 12px; }
        .btn-outline { background: transparent; border: 1px solid #ddd; color: #333; }
        
        .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; background: #fff; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
        table { width: 100%; min-width: 580px; border-collapse: collapse; }
        th { background: #fafafa; font-size: 12px; font-weight: 600; color: #666; text-align: left; padding: 12px 16px; border-bottom: 1px solid #eee; white-space: nowrap; }
        td { padding: 12px 16px; border-bottom: 1px solid #f0f0f0; font-size: 14px; vertical-align: middle; }
        tr:hover { background: #fafafa; }
        .thumb { width: 40px; height: 40px; border-radius: 6px; object-fit: cover; background: #f0f0f0; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; }
        .badge-active { background: #d4edda; color: #155724; }
        .badge-inactive { background: #f8d7da; color: #721c24; }
        .actions { display: flex; gap: 6px; flex-wrap: nowrap; }
        
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.5); z-index: 1000; justify-content: center; align-items: flex-start; padding: 40px 16px; overflow-y: auto; }
        .modal-overlay.active { display: flex; }
        .modal { background: #fff; border-radius: 16px; padding: 32px; width: 520px; max-width: 100%; max-height: none; }
        .modal h2 { font-size: 18px; margin-bottom: 20px; }
        .form-group { margin-bottom: 14px; }
        .form-group label { display: block; font-size: 13px; font-weight: 500; color: #555; margin-bottom: 4px; }
        .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 10px 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; outline: none; transition: border-color .2s; }
        .form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: #171717; }
        .form-group textarea { resize: vertical; min-height: 80px; }
        .form-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }
        .flash { padding: 10px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 14px; }
        .flash-success { background: #d4edda; color: #155724; }
        .flash-error { background: #f8d7da; color: #721c24; }
        .flash-warning { background: #fff3cd; color: #856404; }
        .flash-info { background: #d1ecf1; color: #0c5460; }
        .link { color: #171717; text-decoration: none; }
        .link:hover { text-decoration: underline; }
        
        .cloud-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; letter-spacing: .3px; }
        .cloud-quark { background: #e8f4fd; color: #1a73e8; }
        .cloud-baidu { background: #e8f0fe; color: #306cda; }
        .cloud-aliyun { background: #fff7e6; color: #ff6a00; }
        .cloud-123pan { background: #e6f7ff; color: #1890ff; }
        .cloud-xunlei { background: #f0f5ff; color: #2f54eb; }
        .cloud-lanzou { background: #f6ffed; color: #52c41a; }
        .cloud-other { background: #f5f5f5; color: #888; }

        .empty { text-align: center; padding: 48px; color: #999; }
        .empty p { margin-bottom: 12px; }
        
        .img-input-group { position: relative; }
        .img-input-tabs { display: flex; gap: 0; margin-bottom: 8px; }
        .img-input-tab { padding: 6px 14px; font-size: 12px; border: 1px solid #ddd; background: #fafafa; color: #666; cursor: pointer; transition: all .15s; }
        .img-input-tab:first-child { border-radius: 6px 0 0 6px; }
        .img-input-tab:last-child { border-radius: 0 6px 6px 0; border-left: none; }
        .img-input-tab.active { background: #171717; color: #fff; border-color: #171717; }
        .img-input-panel { display: none; }
        .img-input-panel.active { display: block; }
        
        .upload-area { border: 2px dashed #ddd; border-radius: 8px; padding: 16px; text-align: center; cursor: pointer; transition: border-color .2s, background .2s; position: relative; }
        .upload-area:hover { border-color: #171717; background: #fafafa; }
        .upload-area.dragover { border-color: #171717; background: #f0f0f0; }
        .upload-area input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
        .upload-area .hint { font-size: 12px; color: #999; margin-top: 4px; }
        .upload-preview { margin-top: 10px; display: none; }
        .upload-preview img { max-width: 200px; max-height: 120px; border-radius: 8px; object-fit: contain; background: #f5f5f5; }
        .upload-preview .remove { display: inline-block; margin-left: 8px; color: #e53e3e; cursor: pointer; font-size: 12px; }
        .form-row { display: flex; gap: 12px; }
        .form-row .form-group { flex: 1; }
        
        @media (max-width: 768px) {
            .stats { grid-template-columns: repeat(2, 1fr); gap: 10px; }
            .stat-card { padding: 14px; }
            .stat-card .num { font-size: 22px; }
            .header { padding: 12px 16px; }
            .header h1 { font-size: 15px; }
            .toolbar { flex-direction: column; gap: 10px; align-items: stretch; }
            .toolbar .btn { text-align: center; }
            .modal { padding: 20px; }
            .form-row { flex-direction: column; gap: 0; }
            td.name-cell { max-width: 100px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
            th:nth-child(1), td:nth-child(1) { display: none; }
            th, td { padding: 8px 8px; font-size: 12px; }
            .thumb { width: 32px; height: 32px; }
            .actions { flex-direction: column; gap: 4px; }
            .btn-sm { padding: 3px 8px; font-size: 11px; }
            .badge { font-size: 10px; padding: 1px 6px; }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>资源管理</h1>
        <div>
            <a href="/">← 返回首页</a>
            <span style="margin:0 8px;color:#555;">|</span>
            <span style="color:#aaa;font-size:14px;">{{ current_user.username }}</span>
        </div>
    </div>

    <div class="container">
        {% with messages = get_flashed_messages(with_categories=true) %}
            {% for cat, msg in messages %}
                <div class="flash flash-{{ cat }}">{{ msg }}</div>
            {% endfor %}
        {% endwith %}

        <div class="stats">
            <div class="stat-card">
                <h3>我发布的资源</h3>
                <div class="num">{{ stats.my_products }}</div>
            </div>
            <div class="stat-card">
                <h3>上架中</h3>
                <div class="num">{{ stats.my_active }}</div>
            </div>
        </div>

        <div class="toolbar">
            <h2>我的资源</h2>
            <button class="btn btn-primary" onclick="openModal('add')">+ 发布资源</button>
        </div>

        {% if products %}
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>图片</th>
                        <th>名称</th>
                        <th>分类</th>
                        <th>网盘</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    {% for p in products %}
                    <tr>
                        <td>{{ p.id }}</td>
                        <td>
                            {% if p.image_url %}
                                <img class="thumb" src="{{ p.image_url }}" alt="">
                            {% else %}
                                <div class="thumb" style="display:flex;align-items:center;justify-content:center;font-size:16px;color:#ccc;">-</div>
                            {% endif %}
                        </td>
                        <td class="name-cell"><a class="link" href="/product/{{ p.id }}" target="_blank">{{ p.name }}</a></td>
                        <td>{{ p.category or '-' }}</td>
                        <td>
                            {% if p.cloud_type %}
                                <span class="cloud-badge cloud-{{ p.cloud_type }}">{{ {'quark':'夸克','baidu':'百度','aliyun':'阿里云','123pan':'123云','xunlei':'迅雷','lanzou':'蓝奏','other':'其他'}.get(p.cloud_type, p.cloud_type) }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if p.is_active %}
                                <span class="badge badge-active">上架</span>
                            {% else %}
                                <span class="badge badge-inactive">下架</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="actions">
                                <button class="btn btn-outline btn-sm" onclick='editProduct({{ p|tojson }})'>编辑</button>
                                <form method="POST" action="/dashboard/delete/{{ p.id }}" style="display:inline;" onsubmit="return confirm('确定删除？')">
                                    <button class="btn btn-danger btn-sm" type="submit">删除</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
            <div class="empty">
                <p>你还没有发布任何资源</p>
                <button class="btn btn-primary" onclick="openModal('add')">发布第一个资源</button>
            </div>
        {% endif %}
    </div>

    <!-- 添加/编辑弹窗 -->
    <div class="modal-overlay" id="modal">
        <div class="modal">
            <h2 id="modal-title">发布资源</h2>
            <form method="POST" action="/dashboard/save" id="product-form">
                <input type="hidden" id="form-id" name="id" value="">
                <div class="form-group">
                    <label>资源名称 *</label>
                    <input type="text" name="name" id="form-name" required placeholder="例如：Adobe全家桶">
                </div>
                <div class="form-group">
                    <label>描述</label>
                    <textarea name="description" id="form-desc" placeholder="资源描述"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>分类</label>
                        <select name="category" id="form-cat">
                            <option value="">-- 选择分类 --</option>
                            {% for cat in categories %}
                                <option value="{{ cat }}">{{ cat }}</option>
                            {% endfor %}
                            <option value="__new__">+ 新建分类</option>
                        </select>
                        <input type="text" id="cat-new" name="category" placeholder="输入新分类名称" style="display:none;margin-top:6px;">
                    </div>
                </div>
                
                <div class="form-group">
                    <label>商品图片</label>
                    <div class="img-input-group">
                        <div class="img-input-tabs">
                            <div class="img-input-tab active" onclick="switchImgTab(this, 'img-upload')">上传</div>
                            <div class="img-input-tab" onclick="switchImgTab(this, 'img-url')">URL</div>
                        </div>
                        <div class="img-input-panel active" id="img-upload">
                            <div class="upload-area" id="upload-area-img">
                                <input type="file" id="file-input-img" accept="image/*">
                                <div>点击或拖拽图片到此处</div>
                                <div class="hint">JPG / PNG / WebP，最大 5MB</div>
                            </div>
                            <div class="upload-preview" id="preview-img-wrap">
                                <img id="preview-img" src="" alt="">
                                <span class="remove" onclick="removeImg('img')">删除</span>
                            </div>
                        </div>
                        <div class="img-input-panel" id="img-url">
                            <input type="url" name="image_url" id="form-img" placeholder="https://example.com/image.jpg" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:8px;font-size:14px;outline:none;">
                        </div>
                    </div>
                    <input type="hidden" id="form-img-hidden" name="_image_url_hidden">
                </div>

                <div class="form-group">
                    <label>缩略图（可选，不填用商品图片）</label>
                    <div class="img-input-group">
                        <div class="img-input-tabs">
                            <div class="img-input-tab active" onclick="switchImgTab(this, 'thumb-upload')">上传</div>
                            <div class="img-input-tab" onclick="switchImgTab(this, 'thumb-url')">URL</div>
                        </div>
                        <div class="img-input-panel active" id="thumb-upload">
                            <div class="upload-area" id="upload-area-thumb">
                                <input type="file" id="file-input-thumb" accept="image/*">
                                <div>点击或拖拽图片到此处</div>
                                <div class="hint">JPG / PNG / WebP，最大 5MB</div>
                            </div>
                            <div class="upload-preview" id="preview-thumb-wrap">
                                <img id="preview-thumb" src="" alt="">
                                <span class="remove" onclick="removeImg('thumb')">删除</span>
                            </div>
                        </div>
                        <div class="img-input-panel" id="thumb-url">
                            <input type="url" name="thumb_url" id="form-thumb" placeholder="https://example.com/thumb.jpg" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:8px;font-size:14px;outline:none;">
                        </div>
                    </div>
                    <input type="hidden" id="form-thumb-hidden" name="_thumb_url_hidden">
                </div>

                <div class="form-group">
                    <label>网盘链接 *</label>
                    <input type="text" name="quark_link" id="form-link" required placeholder="夸克/百度/阿里云等网盘链接">
                </div>
                <div class="form-group">
                    <label>
                        <input type="checkbox" name="is_active" id="form-active" checked> 上架
                    </label>
                </div>
                <div id="cloud-hint" style="margin-top:4px;font-size:12px;color:#888;display:none;"></div>

                <div class="form-actions">
                    <button type="button" class="btn btn-outline" onclick="closeModal()">取消</button>
                    <button type="submit" class="btn btn-primary" id="submit-btn">保存</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openModal(type) {
            document.getElementById('modal').classList.add('active');
            if (type === 'add') {
                document.getElementById('modal-title').textContent = '发布资源';
                document.getElementById('product-form').reset();
                document.getElementById('form-id').value = '';
                document.getElementById('form-active').checked = true;
                removeImg('img');
                removeImg('thumb');
                resetImgTabs('img');
                resetImgTabs('thumb');
            }
        }
        function closeModal() {
            document.getElementById('modal').classList.remove('active');
        }
        function editProduct(p) {
            document.getElementById('modal-title').textContent = '编辑资源';
            document.getElementById('form-id').value = p.id;
            document.getElementById('form-name').value = p.name || '';
            document.getElementById('form-desc').value = p.description || '';
            document.getElementById('form-cat').value = p.category || '';
            document.getElementById('form-link').value = p.quark_link || '';
            document.getElementById('form-active').checked = p.is_active == 1;

            if (p.image_url) {
                if (p.image_url.startsWith('http')) {
                    switchToUrl('img');
                    document.getElementById('form-img').value = p.image_url;
                } else {
                    switchToUpload('img');
                    document.getElementById('preview-img').src = p.image_url;
                    document.getElementById('preview-img-wrap').style.display = 'block';
                }
                document.getElementById('form-img-hidden').value = p.image_url;
            } else {
                removeImg('img');
                resetImgTabs('img');
            }

            if (p.thumb_url) {
                if (p.thumb_url.startsWith('http')) {
                    switchToUrl('thumb');
                    document.getElementById('form-thumb').value = p.thumb_url;
                } else {
                    switchToUpload('thumb');
                    document.getElementById('preview-thumb').src = p.thumb_url;
                    document.getElementById('preview-thumb-wrap').style.display = 'block';
                }
                document.getElementById('form-thumb-hidden').value = p.thumb_url;
            } else {
                removeImg('thumb');
                resetImgTabs('thumb');
            }

            document.getElementById('modal').classList.add('active');
        }

        function switchImgTab(tab, panelId) {
            const group = tab.parentElement;
            group.querySelectorAll('.img-input-tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            const panels = group.parentElement;
            panels.querySelectorAll('.img-input-panel').forEach(p => p.classList.remove('active'));
            document.getElementById(panelId).classList.add('active');
        }
        function switchToUrl(type) {
            const group = document.getElementById(type === 'img' ? 'img-upload' : 'thumb-upload').parentElement;
            const tabs = group.querySelectorAll('.img-input-tab');
            tabs[0].classList.remove('active');
            tabs[1].classList.add('active');
            group.querySelectorAll('.img-input-panel').forEach(p => p.classList.remove('active'));
            document.getElementById(type === 'img' ? 'img-url' : 'thumb-url').classList.add('active');
        }
        function switchToUpload(type) {
            const group = document.getElementById(type === 'img' ? 'img-url' : 'thumb-url').parentElement;
            const tabs = group.querySelectorAll('.img-input-tab');
            tabs[1].classList.remove('active');
            tabs[0].classList.add('active');
            group.querySelectorAll('.img-input-panel').forEach(p => p.classList.remove('active'));
            document.getElementById(type === 'img' ? 'img-upload' : 'thumb-upload').classList.add('active');
        }
        function resetImgTabs(type) {
            const group = document.getElementById(type === 'img' ? 'img-upload' : 'thumb-upload').parentElement;
            const tabs = group.querySelectorAll('.img-input-tab');
            tabs[0].classList.add('active');
            tabs[1].classList.remove('active');
            group.querySelectorAll('.img-input-panel').forEach(p => p.classList.remove('active'));
            document.getElementById(type === 'img' ? 'img-upload' : 'thumb-upload').classList.add('active');
        }

        function setupUpload(areaId, inputId, previewId, hiddenId, type) {
            const area = document.getElementById(areaId);
            const input = document.getElementById(inputId);
            const previewWrap = document.getElementById(previewId);
            const previewImg = previewWrap.querySelector('img');
            const hidden = document.getElementById(hiddenId);

            area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('dragover'); });
            area.addEventListener('dragleave', () => area.classList.remove('dragover'));
            area.addEventListener('drop', e => {
                e.preventDefault(); area.classList.remove('dragover');
                if (e.dataTransfer.files.length) doUpload(e.dataTransfer.files[0], previewImg, previewWrap, hidden);
            });
            input.addEventListener('change', function() {
                if (this.files.length) doUpload(this.files[0], previewImg, previewWrap, hidden);
            });
        }
        function doUpload(file, previewImg, previewWrap, hidden) {
            if (file.size > 5 * 1024 * 1024) { alert('图片不能超过5MB'); return; }
            const fd = new FormData();
            fd.append('file', file);
            const btn = document.getElementById('submit-btn');
            btn.textContent = '上传中...'; btn.disabled = true;
            fetch('/dashboard/upload', { method: 'POST', body: fd })
                .then(r => r.json())
                .then(data => {
                    if (data.url) {
                        hidden.value = data.url;
                        previewImg.src = data.url;
                        previewWrap.style.display = 'block';
                    } else { alert(data.error || '上传失败'); }
                })
                .catch(() => alert('上传失败'))
                .finally(() => { btn.textContent = '保存'; btn.disabled = false; });
        }
        function removeImg(type) {
            const hiddenId = type === 'img' ? 'form-img-hidden' : 'form-thumb-hidden';
            const previewWrapId = type === 'img' ? 'preview-img-wrap' : 'preview-thumb-wrap';
            const inputId = type === 'img' ? 'file-input-img' : 'file-input-thumb';
            const urlInputId = type === 'img' ? 'form-img' : 'form-thumb';
            document.getElementById(hiddenId).value = '';
            document.getElementById(previewWrapId).style.display = 'none';
            document.getElementById(previewWrapId).querySelector('img').src = '';
            document.getElementById(inputId).value = '';
            if (document.getElementById(urlInputId)) document.getElementById(urlInputId).value = '';
        }

        document.getElementById('form-cat').addEventListener('change', function() {
            var newInput = document.getElementById('cat-new');
            if (this.value === '__new__') {
                newInput.style.display = 'block';
                newInput.focus();
                this.name = '_cat_unused';
                newInput.name = 'category';
            } else {
                newInput.style.display = 'none';
                newInput.value = '';
                this.name = 'category';
                newInput.name = '_cat_unused';
            }
        });

        var cloudNames = {quark:'夸克网盘',baidu:'百度网盘',aliyun:'阿里云盘','123pan':'123云盘',xunlei:'迅雷网盘',lanzou:'蓝奏云',guangya:'光鸭网盘','115pan':'115云盘',other:'其他网盘'};
        var cloudPatterns = {quark:/quark/i,baidu:/baidu/i,aliyun:/alipan|aliyundrive/i,'123pan':/123pan/i,xunlei:/xunlei/i,lanzou:/lanzou/i};
        function detectCloud(url) {
            for (var k in cloudPatterns) { if (cloudPatterns[k].test(url)) return k; }
            return url ? 'other' : null;
        }
        document.getElementById('form-link').addEventListener('input', function() {
            var hint = document.getElementById('cloud-hint');
            var type = detectCloud(this.value);
            if (type) {
                hint.textContent = '识别为：' + cloudNames[type];
                hint.style.display = 'block';
            } else {
                hint.style.display = 'none';
            }
        });

        setupUpload('upload-area-img', 'file-input-img', 'preview-img-wrap', 'form-img-hidden', 'img');
        setupUpload('upload-area-thumb', 'file-input-thumb', 'preview-thumb-wrap', 'form-thumb-hidden', 'thumb');

        document.getElementById('product-form').addEventListener('submit', function(e) {
            var imgTabs = document.querySelector('#img-upload').parentElement.querySelectorAll('.img-input-tab');
            var imgUrlInput = document.getElementById('form-img');
            var imgHidden = document.getElementById('form-img-hidden');
            if (imgTabs[0].classList.contains('active')) {
                imgUrlInput.name = '';
                imgHidden.name = 'image_url';
            } else {
                imgHidden.value = imgUrlInput.value.trim();
                imgUrlInput.name = '';
                imgHidden.name = 'image_url';
            }

            var thumbTabs = document.querySelector('#thumb-upload').parentElement.querySelectorAll('.img-input-tab');
            var thumbUrlInput = document.getElementById('form-thumb');
            var thumbHidden = document.getElementById('form-thumb-hidden');
            if (thumbTabs[0].classList.contains('active')) {
                thumbUrlInput.name = '';
                thumbHidden.name = 'thumb_url';
            } else {
                thumbHidden.value = thumbUrlInput.value.trim();
                thumbUrlInput.name = '';
                thumbHidden.name = 'thumb_url';
            }
        });
    </script>
</body>
</html>
