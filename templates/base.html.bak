<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}27c.site - 网盘资源分享站 | 网盘自动发货{% endblock %}</title>
    <meta name="description" content="{% block meta_desc %}27c.site 精选软件商店，全部免费，网盘自动发货。提供Adobe全家桶、视频剪辑工具、AI工具、学习资料等精选资源。{% endblock %}">
    <meta name="keywords" content="资源分享,网盘资源,网盘,Adobe,视频剪辑,AI工具,Python教程,ComfyUI,效率工具,自动发货">
    <meta property="og:title" content="{% block og_title %}27c.site - 网盘资源分享站{% endblock %}">
    <meta property="og:description" content="{% block og_desc %}全部免费，网盘自动发货。精选网盘资源。{% endblock %}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://27c.site">
    <link rel="canonical" href="https://27c.site">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css', v=8) }}">
    {% block extra_css %}{% endblock %}
</head>
<body>
    <nav>
        <div class="nav-inner">
            <a href="{{ url_for('index') }}" class="logo">27c.site</a>
            <div class="nav-links">
                <a href="{{ url_for('index') }}">软件</a>
                {% if current_user %}
                    <a href="{{ url_for('dashboard') }}">管理</a>
                    <span class="nav-user">{{ current_user.username }}</span>
                    <a href="{{ url_for('logout') }}" class="nav-btn-sm">退出</a>
                {% else %}
                    <a href="{{ url_for('login') }}" class="nav-btn-sm">登录</a>
                    <a href="{{ url_for('register') }}" class="nav-btn">注册</a>
                {% endif %}
            </div>
            <button class="nav-toggle" onclick="document.querySelector('.nav-links').classList.toggle('open')">☰</button>
        </div>
    </nav>

    <main>
        {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                <div class="flash-container">
                    {% for category, message in messages %}
                        <div class="flash flash-{{ category }}">{{ message }}</div>
                    {% endfor %}
                </div>
            {% endif %}
        {% endwith %}

        {% if error_code %}
            <div class="error-page">
                <h1>{{ error_code }}</h1>
                <p>{{ error_msg }}</p>
                <a href="{{ url_for('index') }}" class="btn btn-primary">返回首页</a>
            </div>
        {% else %}
            {% block content %}{% endblock %}
        {% endif %}
    </main>

    <footer>
        <p>© 2026 27c.site · 网盘资源分享站</p>
        <p class="footer-links">
            <a href="{{ url_for('index') }}">首页</a> ·
            <a href="/about.html">关于</a> ·
            <a href="/privacy.html">隐私政策</a> ·
            <a href="https://www.qiyuan.icu" target="_blank">博客</a>
        </p>
    </footer>

    <script src="{{ url_for('static', filename='js/main.js') }}"></script>
    {% block extra_js %}{% endblock %}
</body>
</html>
